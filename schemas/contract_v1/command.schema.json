{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "uav_id",
    "timestamp",
    "command_id",
    "type",
    "params"
  ],
  "properties": {
    "protocol_version": {
      "type": "integer",
      "const": 1
    },
    "uav_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "command_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["START", "ABORT", "RTL", "ORBIT", "APPLY_ROUTE", "LAND"]
    },
    "params": {
      "type": "object"
    }
  }
}
